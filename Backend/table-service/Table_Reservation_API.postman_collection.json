		{
			"name": "🍽️ 2. Table Management",
			"item": [
				{
					"name": "Get All Tables",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BASE_URL_TABLE}}/api/tables",
							"host": ["{{BASE_URL_TABLE}}"],
							"path": ["api", "tables"]
						}
					}
				},
				{
					"name": "Search Tables - Tomorrow Evening",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BASE_URL_TABLE}}/api/tables/search?date=2025-08-09&startTime=19:00&endTime=21:00&partySize=4",
							"host": ["{{BASE_URL_TABLE}}"],
							"path": ["api", "tables", "search"],
							"query": [
								{
									"key": "date",
									"value": "2025-08-09"
								},
								{
									"key": "startTime",
									"value": "19:00"
								},
								{
									"key": "endTime",
									"value": "21:00"
								},
								{
									"key": "partySize",
									"value": "4"
								}
							]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has tables\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.eql(true);",
									"    pm.expect(jsonData.data.tables).to.be.an('array');",
									"});",
									"",
									"// Save first table ID for reservation",
									"if (pm.response.json().data.tables.length > 0) {",
									"    pm.environment.set(\"TABLE_ID\", pm.response.json().data.tables[0]._id);",
									"    console.log(\"Saved TABLE_ID:\", pm.response.json().data.tables[0]._id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				},
